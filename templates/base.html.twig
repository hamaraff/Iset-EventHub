<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Welcome{% endblock %} - ISET EventHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
        :root {
            --eh-primary: #2563eb;
            --eh-secondary: #e2e8f0;
            --eh-accent: #38bdf8;
            --eh-bg: #f8fafc;
            --eh-card: #ffffff;
            --eh-text: #0f172a;
            --eh-text-muted: #64748b;
            --eh-border: #e2e8f0;
        }

        body {
            background: var(--eh-bg);
            color: var(--eh-text);
        }

        .eh-navbar {
            background: var(--eh-card);
            border-bottom: 1px solid var(--eh-border);
            box-shadow: 0 1px 0 rgba(15, 23, 42, 0.04);
        }

        .eh-card {
            background: var(--eh-card);
            border: 1px solid var(--eh-border);
            box-shadow: 0 12px 24px rgba(15, 23, 42, 0.04);
        }

        .eh-muted {
            color: var(--eh-text-muted);
        }

        .eh-link {
            color: var(--eh-text-muted);
            text-decoration: none;
        }

        .eh-link:hover {
            color: var(--eh-primary);
        }

        .btn-eh-primary {
            background: var(--eh-primary);
            border-color: var(--eh-primary);
            color: #ffffff;
        }

        .btn-eh-primary:hover {
            background: #1d4ed8;
            border-color: #1d4ed8;
            color: #ffffff;
        }

        .btn-eh-accent {
            background: var(--eh-accent);
            border-color: var(--eh-accent);
            color: #0f172a;
        }

        .btn-eh-accent:hover {
            background: #0ea5e9;
            border-color: #0ea5e9;
            color: #0f172a;
        }

        .eh-input {
            background: #ffffff;
            border: 1px solid var(--eh-border);
            color: var(--eh-text);
        }

        .eh-input:focus {
            border-color: var(--eh-primary);
            box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.15);
        }

        .eh-table thead th {
            background: #f1f5f9;
            color: var(--eh-text);
            border-bottom: 1px solid var(--eh-border);
        }

        .eh-table td,
        .eh-table th {
            border-color: var(--eh-border);
        }

        .eh-border {
            border-color: var(--eh-border) !important;
        }

        .eh-badge {
            background: rgba(37, 99, 235, 0.12);
            color: var(--eh-primary);
            border: 1px solid rgba(37, 99, 235, 0.35);
        }

        .home-hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            background-image: linear-gradient(180deg, rgba(15, 23, 42, 0.65), rgba(15, 23, 42, 0.65)), url('{{ asset('assets/images/events/event 6.jpg') }}');
            background-size: cover;
            background-position: center;
            position: relative;
        }

        .home-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: rgba(15, 23, 42, 0.35);
        }

        .home-hero .container {
            position: relative;
            z-index: 1;
        }

        .hero-image-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .hero-image-card {
            border-radius: 1.2rem;
            min-height: 220px;
            background-size: cover;
            background-position: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 24px 48px rgba(15, 23, 42, 0.15);
        }

        .hero-image-card::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.12), rgba(15, 23, 42, 0.65));
        }

        .hero-image-card-large {
            grid-column: span 2;
            min-height: 300px;
        }

        .hero-image-caption {
            position: absolute;
            bottom: 1rem;
            left: 1rem;
            right: 1rem;
            z-index: 1;
            color: #ffffff;
            font-weight: 600;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }

        .section-header h2 {
            font-size: 2rem;
        }

        .section-header p {
            max-width: 720px;
            margin-left: auto;
            margin-right: auto;
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 1rem;
        }

        .calendar-day {
            border: 1px solid var(--eh-border);
            border-radius: 1rem;
            padding: 1rem;
            min-height: 140px;
            background: #ffffff;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .calendar-day:hover {
            transform: translateY(-2px);
            box-shadow: 0 18px 36px rgba(15, 23, 42, 0.08);
        }

        .calendar-day.is-today {
            border-color: #2563eb;
            box-shadow: 0 0 0 1px rgba(37, 99, 235, 0.22);
        }

        .calendar-day .day-label {
            text-transform: uppercase;
            font-size: 0.75rem;
            color: var(--eh-text-muted);
            letter-spacing: 0.08em;
        }

        .calendar-day .day-number {
            font-size: 2rem;
            font-weight: 700;
        }

        .hero-section-photo {
            background-image: url('{{ asset('assets/images/events/event 4.jpg') }}');
            background-size: cover;
            background-position: center;
            color: #ffffff;
        }

        .hero-section-photo .card-body {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.15), rgba(15, 23, 42, 0.85));
        }

        .featured-event-card .card-body {
            display: flex;
            flex-direction: column;
        }

        .featured-event-card .event-meta {
            gap: 0.75rem;
            display: flex;
            flex-wrap: wrap;
        }

        .featured-event-card .event-meta span {
            font-size: 0.82rem;
            color: var(--eh-text-muted);
        }

        .event-card-image,
        .event-detail-image {
            min-height: 180px;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .event-detail-image {
            border-bottom: 1px solid var(--eh-border);
            border-top-left-radius: 0.5rem;
            border-top-right-radius: 0.5rem;
            min-height: 280px;
        }

        .footer-compact {
            border-top: 1px solid var(--eh-border);
            padding-top: 2rem;
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 0.5rem;
        }

        .calendar-header {
            text-transform: uppercase;
            font-size: 0.75rem;
            color: var(--eh-text-muted);
            text-align: center;
            padding: 0.35rem 0.25rem;
        }

        .calendar-day {
            border: 1px solid var(--eh-border);
            border-radius: 0.5rem;
            padding: 0.5rem;
            min-height: 110px;
            background: #ffffff;
        }

        .calendar-day.is-today {
            border-color: #ef4444;
            box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.2);
        }

        .calendar-empty {
            border: 1px dashed var(--eh-border);
            border-radius: 0.5rem;
            min-height: 110px;
            background: #f8fafc;
        }

        .calendar-events {
            max-height: 64px;
            overflow: hidden;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light eh-navbar">
        <div class="container">
            <a class="navbar-brand fw-bold text-dark" href="{{ path('home_index') }}">ISET EventHub</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto gap-2">
                    <li class="nav-item"><a class="nav-link eh-link" href="{{ path('home_index') }}">Home</a></li>
                    <li class="nav-item"><a class="nav-link eh-link" href="{{ path('event_list') }}">Events</a></li>
                    <li class="nav-item"><a class="nav-link eh-link" href="{{ path('calendar_index') }}">Calendar</a></li>
                    {% if app.user %}
                        {% if is_granted('ROLE_ORGANIZER') %}
                            <li class="nav-item"><a class="nav-link eh-link" href="{{ path('organizer_event_index') }}">My events</a></li>
                        {% endif %}
                        {% if not is_granted('ROLE_ADMIN') and not is_granted('ROLE_STAFF') %}
                            <li class="nav-item"><a class="nav-link eh-link" href="{{ path('registration_index') }}">My registrations</a></li>
                        {% endif %}

                        {% if is_granted('ROLE_STAFF') %}
                            <li class="nav-item"><a class="nav-link eh-link" href="{{ path('staff_scan') }}">Scan</a></li>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item"><a class="nav-link eh-link" href="{{ path('admin_event_pending') }}">Pending events</a></li>
                            <li class="nav-item"><a class="nav-link eh-link" href="{{ path('admin_user_index') }}">Users</a></li>
                            <li class="nav-item"><a class="nav-link eh-link" href="{{ path('admin_organization_index') }}">Admin orgs</a></li>
                        {% endif %}
                        <li class="nav-item"><a class="nav-link text-danger" href="{{ path('app_logout') }}">Logout</a></li>
                    {% else %}
                        <li class="nav-item"><a class="nav-link eh-link" href="{{ path('app_login') }}">Login</a></li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    {% block body %}{% endblock %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
