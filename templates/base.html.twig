<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Welcome{% endblock %} - ISET EventHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
        :root {
            --eh-primary: #2563eb;
            --eh-secondary: #e2e8f0;
            --eh-accent: #38bdf8;
            --eh-bg: #f8fafc;
            --eh-card: #ffffff;
            --eh-text: #0f172a;
            --eh-text-muted: #64748b;
            --eh-border: #e2e8f0;
        }

        body {
            background: var(--eh-bg);
            color: var(--eh-text);
        }

        .eh-navbar {
            background: var(--eh-card);
            border-bottom: 1px solid var(--eh-border);
            box-shadow: 0 1px 0 rgba(15, 23, 42, 0.04);
        }

        .eh-card {
            background: var(--eh-card);
            border: 1px solid var(--eh-border);
            box-shadow: 0 12px 24px rgba(15, 23, 42, 0.04);
        }

        .eh-muted {
            color: var(--eh-text-muted);
        }

        .eh-link {
            color: var(--eh-text-muted);
            text-decoration: none;
        }

        .eh-link:hover {
            color: var(--eh-primary);
        }

        .btn-eh-primary {
            background: var(--eh-primary);
            border-color: var(--eh-primary);
            color: #ffffff;
        }

        .btn-eh-primary:hover {
            background: #1d4ed8;
            border-color: #1d4ed8;
            color: #ffffff;
        }

        .btn-eh-accent {
            background: var(--eh-accent);
            border-color: var(--eh-accent);
            color: #0f172a;
        }

        .btn-eh-accent:hover {
            background: #0ea5e9;
            border-color: #0ea5e9;
            color: #0f172a;
        }

        .eh-input {
            background: #ffffff;
            border: 1px solid var(--eh-border);
            color: var(--eh-text);
        }

        .eh-input:focus {
            border-color: var(--eh-primary);
            box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.15);
        }

        .eh-table thead th {
            background: #f1f5f9;
            color: var(--eh-text);
            border-bottom: 1px solid var(--eh-border);
        }

        .eh-table td,
        .eh-table th {
            border-color: var(--eh-border);
        }

        .eh-border {
            border-color: var(--eh-border) !important;
        }

        .eh-badge {
            background: rgba(37, 99, 235, 0.12);
            color: var(--eh-primary);
            border: 1px solid rgba(37, 99, 235, 0.35);
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 0.5rem;
        }

        .calendar-header {
            text-transform: uppercase;
            font-size: 0.75rem;
            color: var(--eh-text-muted);
            text-align: center;
            padding: 0.35rem 0.25rem;
        }

        .calendar-day {
            border: 1px solid var(--eh-border);
            border-radius: 0.5rem;
            padding: 0.5rem;
            min-height: 110px;
            background: #ffffff;
        }

        .calendar-day.is-today {
            border-color: #ef4444;
            box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.2);
        }

        .calendar-empty {
            border: 1px dashed var(--eh-border);
            border-radius: 0.5rem;
            min-height: 110px;
            background: #f8fafc;
        }

        .calendar-events {
            max-height: 64px;
            overflow: hidden;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light eh-navbar">
        <div class="container">
            <a class="navbar-brand fw-bold text-dark" href="{{ path('event_list') }}">ISET EventHub</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto gap-2">
                    <li class="nav-item"><a class="nav-link eh-link" href="{{ path('event_list') }}">Events</a></li>
                    <li class="nav-item"><a class="nav-link eh-link" href="{{ path('calendar_index') }}">Calendar</a></li>
                    {% if app.user %}
                        <li class="nav-item"><a class="nav-link eh-link" href="{{ path('registration_index') }}">My registrations</a></li>
                        {% if is_granted('ROLE_ORGANIZER') %}
                            <li class="nav-item"><a class="nav-link eh-link" href="{{ path('organizer_event_index') }}">My events</a></li>
                            <li class="nav-item"><a class="nav-link eh-link" href="{{ path('organizer_organization_index') }}">Organizations</a></li>
                        {% endif %}
                        {% if is_granted('ROLE_STAFF') %}
                            <li class="nav-item"><a class="nav-link eh-link" href="{{ path('staff_scan') }}">Scan</a></li>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item"><a class="nav-link eh-link" href="{{ path('admin_event_pending') }}">Pending events</a></li>
                            <li class="nav-item"><a class="nav-link eh-link" href="{{ path('admin_user_index') }}">Users</a></li>
                            <li class="nav-item"><a class="nav-link eh-link" href="{{ path('admin_organization_index') }}">Admin orgs</a></li>
                        {% endif %}
                        <li class="nav-item"><a class="nav-link text-danger" href="{{ path('app_logout') }}">Logout</a></li>
                    {% else %}
                        <li class="nav-item"><a class="nav-link eh-link" href="{{ path('app_login') }}">Login</a></li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>
    <div class="container py-4">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                {% set tone = label == 'success' ? 'success' : (label == 'error' ? 'danger' : 'info') %}
                <div class="alert alert-{{ tone }} mb-3" role="alert">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>
    {% block body %}{% endblock %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
