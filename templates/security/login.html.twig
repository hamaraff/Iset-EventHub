{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-5">
            <div class="card eh-card shadow-lg">
                <div class="card-body p-4 p-lg-5">
                    <div class="text-center mb-4">
                        <span class="badge eh-badge text-uppercase">Access</span>
                        <h1 class="h3 fw-bold mt-3">Welcome back</h1>
                        <p class="eh-muted mb-0">Sign in to manage events and registrations.</p>
                    </div>

                    {% if error %}
                        <div class="alert alert-danger" role="alert">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <form method="post">
                        <div class="mb-3">
                            <label for="inputEmail" class="form-label eh-muted">Email</label>
                            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control eh-input" autocomplete="email" required autofocus>
                        </div>
                        <div class="mb-3">
                            <label for="inputPassword" class="form-label eh-muted">Password</label>
                            <input type="password" name="password" id="inputPassword" class="form-control eh-input" autocomplete="current-password" required>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMe">
                                <label class="form-check-label eh-muted" for="rememberMe">Remember me</label>
                            </div>
                            <a class="eh-link small" href="#">Forgot password?</a>
                        </div>
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                        <button class="btn btn-eh-primary w-100" type="submit">Sign in</button>
                    </form>

                    <div class="text-center mt-4">
                        <span class="eh-muted">Need an account?</span>
                        <a class="eh-link" href="#">Contact admin</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
