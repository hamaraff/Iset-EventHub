{% extends 'base.html.twig' %}

{% block title %}Organizations - Admin{% endblock %}

{% block body %}
<div class="container pb-5">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <span class="badge eh-badge text-uppercase">Admin</span>
            <h1 class="display-6 fw-bold mt-2">Organizations</h1>
            <p class="eh-muted mb-0">Manage organizations and memberships.</p>
        </div>
        <a href="{{ path('admin_organization_create') }}" class="btn btn-eh-primary">Create organization</a>
    </div>

    {% if organizations is empty %}
        <div class="card eh-card text-center">
            <div class="card-body py-5">
                <h2 class="h5 fw-bold mb-2">No organizations found</h2>
                <p class="eh-muted mb-0">Create your first organization to get started.</p>
            </div>
        </div>
    {% else %}
        <div class="card eh-card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 eh-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Members</th>
                                <th>Events</th>
                                <th>Created</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for organization in organizations %}
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            {% if organization.logo %}
                                                <img src="{{ organization.logo }}" alt="{{ organization.name }}" class="rounded-circle" width="40" height="40">
                                            {% else %}
                                                <div class="rounded-circle border d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                    <span class="fw-semibold text-primary">{{ organization.name|first|upper }}</span>
                                                </div>
                                            {% endif %}
                                            <div class="fw-semibold">{{ organization.name }}</div>
                                        </div>
                                    </td>
                                    <td class="small eh-muted">{{ organization.description|default('No description') }}</td>
                                    <td><span class="badge text-bg-primary">{{ organization.members|length }}</span></td>
                                    <td><span class="badge text-bg-success">{{ organization.events|length }}</span></td>
                                    <td>{{ organization.createdAt|date('M j, Y') }}</td>
                                    <td class="text-end">
                                        <a href="{{ path('admin_organization_edit', {'id': organization.id}) }}" class="btn btn-sm btn-outline-secondary">Edit</a>
                                        <a href="{{ path('admin_organization_members', {'id': organization.id}) }}" class="btn btn-sm btn-outline-secondary">Members</a>
                                        <form method="post" action="{{ path('admin_organization_delete', {'id': organization.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this organization?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
