{% extends 'base.html.twig' %}

{% block title %}Manage Members - {{ organization.name }} - Admin{% endblock %}

{% block body %}
<div class="container pb-5">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <span class="badge eh-badge text-uppercase">Admin</span>
            <h1 class="display-6 fw-bold mt-2">Manage members</h1>
            <p class="eh-muted mb-0">Organization: <strong>{{ organization.name }}</strong></p>
        </div>
        <a href="{{ path('admin_organization_index') }}" class="btn btn-outline-secondary">Back to organizations</a>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-6">
            <div class="card eh-card h-100">
                <div class="card-body">
                    <h2 class="h5 fw-bold mb-3">Current members ({{ members|length }})</h2>
                    {% if members is empty %}
                        <p class="eh-muted mb-0">No members yet.</p>
                    {% else %}
                        <div class="list-group list-group-flush">
                            {% for member in members %}
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <span class="fw-semibold">{{ member.name|first|upper }}</span>
                                        </div>
                                        <div>
                                            <div class="fw-semibold">{{ member.name }}</div>
                                            <div class="small eh-muted">{{ member.email }}</div>
                                        </div>
                                    </div>
                                    <form method="post" action="{{ path('admin_organization_members', {'id': organization.id}) }}" onsubmit="return confirm('Remove {{ member.name }} from this organization?');">
                                        <input type="hidden" name="action" value="remove">
                                        <input type="hidden" name="user_id" value="{{ member.id }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                    </form>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card eh-card h-100">
                <div class="card-body">
                    <h2 class="h5 fw-bold mb-3">Add members</h2>
                    {% if nonMembers is empty %}
                        <p class="eh-muted mb-0">All users are already members.</p>
                    {% else %}
                        <div class="list-group list-group-flush">
                            {% for user in nonMembers %}
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-success-subtle text-success d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <span class="fw-semibold">{{ user.name|first|upper }}</span>
                                        </div>
                                        <div>
                                            <div class="fw-semibold">{{ user.name }}</div>
                                            <div class="small eh-muted">{{ user.email }}</div>
                                        </div>
                                    </div>
                                    <form method="post" action="{{ path('admin_organization_members', {'id': organization.id}) }}">
                                        <input type="hidden" name="action" value="add">
                                        <input type="hidden" name="user_id" value="{{ user.id }}">
                                        <button type="submit" class="btn btn-sm btn-eh-primary">Add</button>
                                    </form>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
