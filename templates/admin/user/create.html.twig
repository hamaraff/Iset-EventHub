{% extends 'base.html.twig' %}

{% block title %}Create User{% endblock %}

{% block body %}
<div class="container pb-5">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <span class="badge eh-badge text-uppercase">Admin</span>
            <h1 class="display-6 fw-bold mt-2">Create user</h1>
            <p class="eh-muted mb-0">Add a new account and assign roles.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="{{ path('admin_user_index') }}">Back to users</a>
        </div>
    </div>

    <div class="card eh-card">
        <div class="card-body">
            <form method="post" class="row g-3">
                <div class="col-12">
                    <label class="form-label eh-muted" for="name">Name</label>
                    <input class="form-control eh-input" id="name" name="name" required>
                </div>
                <div class="col-12">
                    <label class="form-label eh-muted" for="email">Email</label>
                    <input class="form-control eh-input" id="email" name="email" type="email" required>
                </div>
                <div class="col-12">
                    <label class="form-label eh-muted" for="password">Password</label>
                    <input class="form-control eh-input" id="password" name="password" type="password" required>
                </div>
                <div class="col-12">
                    <label class="form-label eh-muted">Roles</label>
                    <div class="d-flex flex-wrap gap-3">
                        {% for role, label in availableRoles %}
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="roles[]" value="{{ role }}" id="role_{{ role }}">
                                <label class="form-check-label" for="role_{{ role }}">{{ label }}</label>
                            </div>
                        {% endfor %}
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label eh-muted" for="organization_ids">Clubs / Organizations</label>
                    <select class="form-select eh-input" id="organization_ids" name="organization_ids[]" multiple>
                        {% for organization in organizations %}
                            <option value="{{ organization.id }}">{{ organization.name }}</option>
                        {% endfor %}
                    </select>
                    <div class="form-text">Select clubs for participant membership. Organizer users will receive an organization automatically.</div>
                </div>
                <div class="col-12 d-flex flex-wrap gap-2">
                    <button class="btn btn-eh-primary" type="submit">Create user</button>
                    <a class="btn btn-outline-secondary" href="{{ path('admin_user_index') }}">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
