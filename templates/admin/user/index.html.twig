{% extends 'base.html.twig' %}

{% block title %}Users{% endblock %}

{% block body %}
<div class="container pb-5">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <span class="badge eh-badge text-uppercase">Admin</span>
            <h1 class="display-6 fw-bold mt-2">Users</h1>
            <p class="eh-muted mb-0">Manage user accounts and roles.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-eh-primary" href="{{ path('admin_user_create') }}">Create user</a>
        </div>
    </div>

    <div class="card eh-card">
        <div class="card-body">
            {% if users is empty %}
                <p class="eh-muted mb-0">No users found.</p>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 eh-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Roles</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in users %}
                                <tr>
                                    <td>{{ user.name }}</td>
                                    <td>{{ user.email }}</td>
                                    <td>
                                        {% for role in user.roles %}
                                            <span class="badge bg-secondary me-1">{{ role }}</span>
                                        {% endfor %}
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('admin_user_roles', { id: user.id }) }}">Manage roles</a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
