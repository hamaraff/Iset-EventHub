{% extends 'base.html.twig' %}

{% block title %}Manage Roles{% endblock %}

{% block body %}
<div class="container pb-5">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <span class="badge eh-badge text-uppercase">Admin</span>
            <h1 class="display-6 fw-bold mt-2">Manage roles</h1>
            <p class="eh-muted mb-0">Update roles for {{ user.email }}.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="{{ path('admin_user_index') }}">Back to users</a>
        </div>
    </div>

    <div class="card eh-card">
        <div class="card-body">
            <form method="post">
                <div class="mb-4">
                    {% for role, label in availableRoles %}
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="roles[]" value="{{ role }}" id="role_{{ role }}" {% if role in user.roles %}checked{% endif %}>
                            <label class="form-check-label" for="role_{{ role }}">{{ label }}</label>
                        </div>
                    {% endfor %}
                </div>
                <button class="btn btn-eh-primary" type="submit">Save roles</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
