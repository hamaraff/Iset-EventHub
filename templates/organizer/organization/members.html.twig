{% extends 'base.html.twig' %}

{% block title %}Manage Members - {{ organization.name }} - Organizer{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-6xl mx-auto">
        <div class="mb-6">
            <a href="{{ path('organizer_organization_index') }}" 
               class="text-blue-600 hover:text-blue-800 font-medium">
                ← Back to My Organizations
            </a>
        </div>

        <div class="mb-8">
            <h1 class="text-3xl font-bold text-slate-900 mb-2">Manage Members</h1>
            <p class="text-slate-600">Organization: <strong>{{ organization.name }}</strong></p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Current Members -->
            <div class="bg-white rounded-lg shadow-sm">
                <div class="p-6 border-b border-slate-200">
                    <h2 class="text-xl font-semibold text-slate-900">Current Members ({{ members|length }})</h2>
                </div>
                <div class="p-6">
                    {% if members is empty %}
                        <p class="text-slate-500 text-center py-8">No members yet</p>
                    {% else %}
                        <ul class="space-y-3">
                            {% for member in members %}
                                <li class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                                    <div class="flex items-center">
                                        <div class="h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center mr-3">
                                            <span class="text-blue-600 font-medium">{{ member.name|first|upper }}</span>
                                        </div>
                                        <div>
                                            <p class="font-medium text-slate-900">{{ member.name }}</p>
                                            <p class="text-sm text-slate-500">{{ member.email }}</p>
                                        </div>
                                    </div>
                                    <form method="post" action="{{ path('organizer_organization_members', {'id': organization.id}) }}" 
                                          onsubmit="return confirm('Remove {{ member.name }} from this organization?');">
                                        <input type="hidden" name="action" value="remove">
                                        <input type="hidden" name="user_id" value="{{ member.id }}">
                                        <button type="submit" class="text-red-600 hover:text-red-800 text-sm font-medium">
                                            Remove
                                        </button>
                                    </form>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>

            <!-- Add Members -->
            <div class="bg-white rounded-lg shadow-sm">
                <div class="p-6 border-b border-slate-200">
                    <h2 class="text-xl font-semibold text-slate-900">Add Members</h2>
                </div>
                <div class="p-6">
                    {% if nonMembers is empty %}
                        <p class="text-slate-500 text-center py-8">All users are already members</p>
                    {% else %}
                        <ul class="space-y-3">
                            {% for user in nonMembers %}
                                <li class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                                    <div class="flex items-center">
                                        <div class="h-10 w-10 rounded-full bg-green-100 flex items-center justify-center mr-3">
                                            <span class="text-green-600 font-medium">{{ user.name|first|upper }}</span>
                                        </div>
                                        <div>
                                            <p class="font-medium text-slate-900">{{ user.name }}</p>
                                            <p class="text-sm text-slate-500">{{ user.email }}</p>
                                        </div>
                                    </div>
                                    <form method="post" action="{{ path('organizer_organization_members', {'id': organization.id}) }}">
                                        <input type="hidden" name="action" value="add">
                                        <input type="hidden" name="user_id" value="{{ user.id }}">
                                        <button type="submit" class="px-3 py-1 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">
                                            Add
                                        </button>
                                    </form>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>
        </div>
</div>
{% endblock %}
