{% extends 'base.html.twig' %}

{% block title %}My Organizations - Organizer{% endblock %}

{% block body %}
<div class="container pb-5">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <span class="badge eh-badge text-uppercase">Organizer</span>
            <h1 class="display-6 fw-bold mt-2">My organizations</h1>
            <p class="eh-muted mb-0">Create and manage your organization spaces.</p>
        </div>
        <a href="{{ path('organizer_organization_create') }}" class="btn btn-eh-primary">Create organization</a>
    </div>

    {% if organizations is empty %}
        <div class="card eh-card text-center">
            <div class="card-body py-5">
                <h2 class="h5 fw-bold mb-2">No organizations yet</h2>
                <p class="eh-muted mb-3">Create your first organization to start managing events.</p>
                <a href="{{ path('organizer_organization_create') }}" class="btn btn-eh-primary">Create organization</a>
            </div>
        </div>
    {% else %}
        <div class="row g-4">
            {% for organization in organizations %}
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card eh-card h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                {% if organization.logo %}
                                    <img src="{{ organization.logo }}" alt="{{ organization.name }}" class="rounded-circle" width="48" height="48">
                                {% else %}
                                    <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                        <span class="fw-bold">{{ organization.name|first|upper }}</span>
                                    </div>
                                {% endif %}
                                <div>
                                    <h3 class="h5 fw-bold mb-0">{{ organization.name }}</h3>
                                    <p class="small eh-muted mb-0">{{ organization.description|default('No description provided') }}</p>
                                </div>
                            </div>

                            <div class="d-flex flex-wrap gap-3 small eh-muted">
                                <span>{{ organization.members|length }} members</span>
                                <span>{{ organization.events|length }} events</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top eh-border d-flex align-items-center justify-content-between">
                            <a href="{{ path('organizer_organization_view', {'id': organization.id}) }}" class="btn btn-sm btn-outline-secondary">View</a>
                            <div class="d-flex gap-2">
                                <a href="{{ path('organizer_organization_edit', {'id': organization.id}) }}" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a href="{{ path('organizer_organization_members', {'id': organization.id}) }}" class="btn btn-sm btn-outline-secondary">Members</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
