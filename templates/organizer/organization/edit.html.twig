{% extends 'base.html.twig' %}

{% block title %}Edit Organization - Organizer{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto">
        <div class="mb-6">
            <a href="{{ path('organizer_organization_index') }}" 
               class="text-blue-600 hover:text-blue-800 font-medium">
                ← Back to My Organizations
            </a>
        </div>

        <div class="bg-white rounded-lg shadow-sm p-8">
            <h1 class="text-2xl font-bold text-slate-900 mb-6">Edit Organization</h1>

            <div class="mb-6 p-4 bg-slate-50 rounded-lg">
                <p class="text-sm text-slate-600">
                    <strong>Organization:</strong> {{ organization.name }}
                </p>
            </div>

            {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
                
                <div>
                    {{ form_label(form.name, 'Organization Name', {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-2'}}) }}
                    {{ form_widget(form.name, {'attr': {'class': 'w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500'}}) }}
                    {% if form.name.vars.errors %}
                        <div class="mt-1 text-sm text-red-600">
                            {{ form_errors(form.name) }}
                        </div>
                    {% endif %}
                </div>

                <div>
                    {{ form_label(form.description, 'Description', {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-2'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500', 'rows': 4}}) }}
                    {% if form.description.vars.errors %}
                        <div class="mt-1 text-sm text-red-600">
                            {{ form_errors(form.description) }}
                        </div>
                    {% endif %}
                    <p class="mt-1 text-sm text-slate-500">Optional: Provide a brief description of your organization.</p>
                </div>

                <div>
                    {{ form_label(form.logo, 'Logo URL', {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-2'}}) }}
                    {{ form_widget(form.logo, {'attr': {'class': 'w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500', 'placeholder': 'https://example.com/logo.png'}}) }}
                    {% if form.logo.vars.errors %}
                        <div class="mt-1 text-sm text-red-600">
                            {{ form_errors(form.logo) }}
                        </div>
                    {% endif %}
                    <p class="mt-1 text-sm text-slate-500">Optional: Enter the URL of your organization logo.</p>
                </div>

                <div class="flex items-center justify-end space-x-4 pt-4">
                    <a href="{{ path('organizer_organization_index') }}" 
                       class="px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition-colors">
                        Cancel
                    </a>
                    <button type="submit" 
                            class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                        Update Organization
                    </button>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
