{% extends 'base.html.twig' %}

{% block title %}Create Organization - Organizer{% endblock %}

{% block body %}
<div class="container pb-5">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <span class="badge eh-badge text-uppercase">Organizer</span>
            <h1 class="display-6 fw-bold mt-2">Create organization</h1>
            <p class="eh-muted mb-0">Start a new organization space for your events.</p>
        </div>
        <a href="{{ path('organizer_organization_index') }}" class="btn btn-outline-secondary">Back to organizations</a>
    </div>

    <div class="card eh-card">
        <div class="card-body">
            <div class="alert alert-info">You will be automatically added as a member of this organization.</div>
            {{ form_start(form, { attr: { class: 'row g-3' } }) }}
                <div class="col-12">
                    {{ form_row(form.name, { label: 'Organization name', label_attr: { class: 'form-label eh-muted' }, attr: { class: 'form-control eh-input' } }) }}
                </div>
                <div class="col-12">
                    {{ form_row(form.description, { label: 'Description', label_attr: { class: 'form-label eh-muted' }, attr: { class: 'form-control eh-input', rows: 4 } }) }}
                    <div class="form-text">Optional: Provide a brief description of your organization.</div>
                </div>
                <div class="col-12">
                    {{ form_row(form.logo, { label: 'Logo', label_attr: { class: 'form-label eh-muted' }, attr: { class: 'form-control eh-input', accept: 'image/*' } }) }}
                    <div class="form-text">Optional: Upload an image file for your organization logo.</div>
                </div>
                <div class="col-12 d-flex flex-wrap gap-2">
                    <a href="{{ path('organizer_organization_index') }}" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-eh-primary">Create organization</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
