{% extends 'base.html.twig' %}

{% block title %}{{ organization.name }} - Organizer{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto">
        <div class="mb-6">
            <a href="{{ path('organizer_organization_index') }}" 
               class="text-blue-600 hover:text-blue-800 font-medium">
                ← Back to My Organizations
            </a>
        </div>

        <div class="bg-white rounded-lg shadow-sm overflow-hidden">
            <!-- Header -->
            <div class="p-8 bg-gradient-to-r from-blue-500 to-blue-600">
                <div class="flex items-center">
                    {% if organization.logo %}
                        <img src="{{ organization.logo }}" alt="{{ organization.name }}" class="h-20 w-20 rounded-full mr-6 border-4 border-white shadow-lg">
                    {% else %}
                        <div class="h-20 w-20 rounded-full bg-white flex items-center justify-center mr-6 border-4 border-white shadow-lg">
                            <span class="text-blue-600 font-bold text-3xl">{{ organization.name|first|upper }}</span>
                        </div>
                    {% endif %}
                    <div>
                        <h1 class="text-3xl font-bold text-white mb-2">{{ organization.name }}</h1>
                        <p class="text-blue-100">Created on {{ organization.createdAt|date('F j, Y') }}</p>
                    </div>
                </div>
            </div>

            <!-- Content -->
            <div class="p-8">
                <!-- Description -->
                <div class="mb-8">
                    <h2 class="text-xl font-semibold text-slate-900 mb-4">Description</h2>
                    <p class="text-slate-600 leading-relaxed">
                        {{ organization.description|default('No description provided.') }}
                    </p>
                </div>

                <!-- Statistics -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                    <div class="bg-slate-50 rounded-lg p-6">
                        <div class="flex items-center">
                            <div class="h-12 w-12 rounded-full bg-blue-100 flex items-center justify-center mr-4">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="w-6 h-6 text-blue-600">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                </svg>
                            </div>
                            <div>
                                <p class="text-3xl font-bold text-slate-900">{{ organization.members|length }}</p>
                                <p class="text-slate-500">Members</p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-slate-50 rounded-lg p-6">
                        <div class="flex items-center">
                            <div class="h-12 w-12 rounded-full bg-green-100 flex items-center justify-center mr-4">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="w-6 h-6 text-green-600">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                            </div>
                            <div>
                                <p class="text-3xl font-bold text-slate-900">{{ organization.events|length }}</p>
                                <p class="text-slate-500">Events</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Members List -->
                <div class="mb-8">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-xl font-semibold text-slate-900">Members</h2>
                        <a href="{{ path('organizer_organization_members', {'id': organization.id}) }}" 
                           class="text-blue-600 hover:text-blue-800 text-sm font-medium">
                            Manage Members →
                        </a>
                    </div>
                    
                    {% if organization.members is empty %}
                        <p class="text-slate-500">No members yet.</p>
                    {% else %}
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            {% for member in organization.members %}
                                <div class="flex items-center p-3 bg-slate-50 rounded-lg">
                                    <div class="h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center mr-3">
                                        <span class="text-blue-600 font-medium">{{ member.name|first|upper }}</span>
                                    </div>
                                    <div>
                                        <p class="font-medium text-slate-900">{{ member.name }}</p>
                                        <p class="text-sm text-slate-500">{{ member.email }}</p>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                <!-- Actions -->
                <div class="flex items-center space-x-4 pt-6 border-t border-slate-200">
                    <a href="{{ path('organizer_organization_edit', {'id': organization.id}) }}" 
                       class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                        Edit Organization
                    </a>
                    <a href="{{ path('organizer_organization_members', {'id': organization.id}) }}" 
                       class="px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition-colors">
                        Manage Members
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
