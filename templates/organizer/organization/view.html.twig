{% extends 'base.html.twig' %}

{% block title %}{{ organization.name }} - Organizer{% endblock %}

{% block body %}
<div class="container pb-5">
    <div class="mb-3">
        <a href="{{ path('organizer_organization_index') }}" class="btn btn-outline-secondary btn-sm">Back to organizations</a>
    </div>

    <div class="card eh-card">
        <div class="card-body border-bottom eh-border">
            <div class="d-flex align-items-center gap-3">
                {% if organization.logo %}
                    <img src="{{ organization.logo }}" alt="{{ organization.name }}" class="rounded-circle" width="72" height="72">
                {% else %}
                    <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center" style="width: 72px; height: 72px;">
                        <span class="fw-bold fs-4">{{ organization.name|first|upper }}</span>
                    </div>
                {% endif %}
                <div>
                    <h1 class="h3 fw-bold mb-1">{{ organization.name }}</h1>
                    <p class="eh-muted mb-0">Created on {{ organization.createdAt|date('F j, Y') }}</p>
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="row g-4">
                <div class="col-12 col-lg-7">
                    <h2 class="h5 fw-bold mb-3">Description</h2>
                    <p class="eh-muted">{{ organization.description|default('No description provided.') }}</p>
                </div>
                <div class="col-12 col-lg-5">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="border rounded p-3 text-center eh-border">
                                <div class="h4 fw-bold mb-0">{{ organization.members|length }}</div>
                                <div class="small eh-muted">Members</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3 text-center eh-border">
                                <div class="h4 fw-bold mb-0">{{ organization.events|length }}</div>
                                <div class="small eh-muted">Events</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h2 class="h5 fw-bold mb-0">Members</h2>
                    <a href="{{ path('organizer_organization_members', {'id': organization.id}) }}" class="btn btn-sm btn-outline-secondary">Manage members</a>
                </div>

                {% if organization.members is empty %}
                    <p class="eh-muted mb-0">No members yet.</p>
                {% else %}
                    <div class="row g-3">
                        {% for member in organization.members %}
                            <div class="col-12 col-md-6">
                                <div class="border rounded p-3 eh-border d-flex align-items-center gap-3">
                                    <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        <span class="fw-semibold">{{ member.name|first|upper }}</span>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">{{ member.name }}</div>
                                        <div class="small eh-muted">{{ member.email }}</div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="mt-4 d-flex flex-wrap gap-2">
                <a href="{{ path('organizer_organization_edit', {'id': organization.id}) }}" class="btn btn-eh-primary">Edit organization</a>
                <a href="{{ path('organizer_organization_members', {'id': organization.id}) }}" class="btn btn-outline-secondary">Manage members</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
