{% extends 'base.html.twig' %}

{% block title %}My Events{% endblock %}

{% block body %}
<div class="container pb-5">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <span class="badge eh-badge text-uppercase">Organizer</span>
            <h1 class="display-6 fw-bold mt-2">My events</h1>
            <p class="eh-muted mb-0">Manage your organization events and submissions.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-eh-primary" href="{{ path('organizer_event_new') }}">Create event</a>
        </div>
    </div>

    <div class="card eh-card">
        <div class="card-body">
            {% if events is empty %}
                <p class="eh-muted mb-0">No events yet. Create your first event.</p>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 eh-table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Dates</th>
                                <th>Status</th>
                                <th>Mode</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for event in events %}
                                {% set statusLabel = event.status %}
                                <tr>
                                    <td>
                                        <div class="fw-semibold">{{ event.title }}</div>
                                        <div class="small eh-muted">{{ event.organization.name }}</div>
                                    </td>
                                    <td>
                                        <div>{{ event.startDate|date('M d, Y H:i') }}</div>
                                        <div class="small eh-muted">to {{ event.endDate|date('M d, Y H:i') }}</div>
                                    </td>
                                    <td>
                                        <span class="badge eh-badge">{{ statusLabel }}</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">{{ event.mode }}</span>
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('event_show', { id: event.id }) }}">View</a>
                                        {% if is_granted('EVENT_EDIT', event) %}
                                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('organizer_event_edit', { id: event.id }) }}">Edit</a>
                                        {% endif %}
                                        {% if is_granted('EVENT_SUBMIT', event) and event.status == constant('App\\Entity\\Event::STATUS_DRAFT') %}
                                            <form method="post" action="{{ path('organizer_event_submit', { id: event.id }) }}" class="d-inline">
                                                <button class="btn btn-sm btn-outline-warning" type="submit">Submit</button>
                                            </form>
                                        {% endif %}
                                        {% if is_granted('EVENT_DELETE', event) and event.status == constant('App\\Entity\\Event::STATUS_DRAFT') %}
                                            <form method="post" action="{{ path('organizer_event_delete', { id: event.id }) }}" class="d-inline">
                                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                            </form>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
